// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Execution {
  id           Int      @id @default(autoincrement())
  date         DateTime
  symbol       String
  qty          Float
  price        Float
  amount       Float
  broker       String   @default("AMR")
  account      String   @default("USA")
  side         String   // BUY, SELL
  isClosed     Boolean  @default(false)
  remainingQty Float    @default(0)
  currency     String   @default("USD")
  commissions  Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relaciones con TradeUnits
  entryTradeUnits  TradeUnit[] @relation("EntryExecution")

  @@index([symbol])
  @@index([date])
  @@index([broker])
}

model CashFlow {
  id          Int      @id @default(autoincrement())
  date        DateTime
  amount      Float
  type        String   // DEPOSIT, WITHDRAWAL
  broker      String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
  @@index([broker])
}

model TradeUnit {
  id              Int      @id @default(autoincrement())
  symbol          String
  qty             Float
  entryDate       DateTime
  exitDate        DateTime?
  entryPrice      Float
  exitPrice       Float?
  entryAmount     Float
  exitAmount      Float?
  days            Int
  pnlNominal      Float
  pnlPercent      Float
  tna             Float
  broker          String
  account         String   @default("USA")
  instrumentType  String   @default("STOCK")
  status          String   @default("OPEN") // OPEN, CLOSED
  side            String   @default("BUY")  // BUY, SELL

  entryExecId  Int?
  entryExec    Execution? @relation("EntryExecution", fields: [entryExecId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([symbol])
  @@index([exitDate])
  @@index([broker])
}
