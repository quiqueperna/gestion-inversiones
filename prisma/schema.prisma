// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Execution {
  id            Int      @id @default(autoincrement())
  userId        String   @default("")
  date          DateTime
  symbol        String
  qty           Float
  price         Float
  amount        Float
  broker        String   @default("AMR")
  account       String   @default("USA")
  side          String   // BUY, SELL
  isClosed      Boolean  @default(false)
  remainingQty  Float    @default(0)
  currency      String   @default("USD")
  commissions   Float    @default(0)
  exchange_rate Float    @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relaciones con TradeUnits
  entryTradeUnits  TradeUnit[] @relation("EntryExecution")
  exitTradeUnits   TradeUnit[] @relation("ExitExecution")

  @@index([symbol])
  @@index([date])
  @@index([broker])
  @@index([userId])
}

model CashFlow {
  id          Int      @id @default(autoincrement())
  userId      String   @default("")
  date        DateTime
  amount      Float
  type        String   // DEPOSIT, WITHDRAWAL
  broker      String
  account     String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
  @@index([broker])
  @@index([userId])
}

model Account {
  id               Int      @id @default(autoincrement())
  userId           String   @default("")
  nombre           String
  descripcion      String?
  matchingStrategy String   @default("FIFO")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([userId, nombre])
}

model Broker {
  id          Int      @id @default(autoincrement())
  userId      String   @default("")
  nombre      String
  descripcion String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, nombre])
}

model TradeUnit {
  id              Int      @id @default(autoincrement())
  userId          String   @default("")
  symbol          String
  qty             Float
  entryDate       DateTime
  exitDate        DateTime?
  entryPrice      Float
  exitPrice       Float?
  entryAmount     Float
  exitAmount      Float?
  days            Int
  pnlNominal      Float
  pnlPercent      Float
  tna             Float
  broker          String
  account         String   @default("USA")
  instrumentType  String   @default("STOCK")
  status          String   @default("OPEN") // OPEN, CLOSED
  side            String   @default("BUY")  // BUY, SELL

  entryExecId  Int?
  entryExec    Execution? @relation("EntryExecution", fields: [entryExecId], references: [id])
  exitExecId   Int?
  exitExec     Execution? @relation("ExitExecution", fields: [exitExecId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([symbol])
  @@index([exitDate])
  @@index([broker])
  @@index([userId])
}
